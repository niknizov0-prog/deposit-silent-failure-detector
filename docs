.log-chrome { background: var(--bg3); padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; }
.log-dots { display: flex; gap: 6px; margin-right: 12px; }
.log-dots span { width: 10px; height: 10px; border-radius: 50%; display:inline-block; }
