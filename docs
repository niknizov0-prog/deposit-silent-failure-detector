<script>
/* Scroll Reveal */
document.addEventListener('DOMContentLoaded', function() {
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('is-visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  /* Log Animation */
  const lines = [
    { time: '14:10', badge: 'OK',   cls: 'badge-ok',   msg: 'Webhook MercadoPago → 200 OK (78ms)' },
    { time: '14:12', badge: 'FAIL', cls: 'badge-err',  msg: 'Webhook Stripe: Silent Drop detectado' },
    { time: '14:12', badge: 'ALRT', cls: 'badge-ok',   msg: 'Alerta enviada a Slack #alerts' }
  ];

  async function startLog() {
    const body = document.getElementById('logBody');
    if (!body) return;
    body.innerHTML = "";
    for(const l of lines) {
      await new Promise(r => setTimeout(r, 1000 + Math.random() * 500));
      const d = document.createElement('div');
      d.className = 'log-line';
      d.innerHTML = `<span style="color:var(--gray3)">${l.time}</span> <span class="badge ${l.cls}">${l.badge}</span> <span style="color:var(--gray1)">${l.msg}</span>`;
      body.appendChild(d);
      setTimeout(() => d.classList.add('visible'), 50);

      if(l.badge === 'FAIL') {
        await new Promise(r => setTimeout(r, 400));
        const alert = document.createElement('div');
        alert.className = 'log-alert';
        alert.textContent = '⚠️ ALERTA CRÍTICA: Pérdida estimada: $420 USD';
        body.appendChild(alert);
      }
    }
  }

  const logBody = document.getElementById('logBody');
  if (logBody) {
    const logObs = new IntersectionObserver(entries => {
      if(entries[0].isIntersecting) { startLog(); logObs.disconnect(); }
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
    logObs.observe(logBody);
  }
});
</script>

