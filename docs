.log-dots span:nth-child(2) { background: #febc2e; }
.log-dots span:nth-child(3) { background: #28c840; }
.log-body { padding: 20px; min-height: 180px; font-size: 13px; display: block }
@media (max-width: 600px) { 
  .log-body { min-height: 160px; }
}
.log-line { opacity: 0; transform: translateY(5px); margin-bottom: 8px; transition: opacity 0.3s var(--ease), transform 0.3s var(--ease); }
.log-line.visible { opacity: 1; transform: translateY(0); }
.badge { padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 700; margin-right: 8px; display:inline-block; }
.badge-ok { background: var(--green-dim); color: var(--green); }
.badge-err { background: var(--red-dim); color: var(--red); }
